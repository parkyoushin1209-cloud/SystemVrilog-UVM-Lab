class reg_file_type extends uvm_reg_file;
`uvm_object_utils(reg_file_type)

reg_type R1;
reg_type R2[3];
reg_file_type2 RF1;

function new(string name = "reg_type");
super.new(name);
endfunction : new

virtual function void build();
  uvm_reg_block blk = get_block();
  R1 = reg_type::type_id::create($sformatf("%s.r1", get_name()), null, blk.get_full_name());
  R1.build();
  R1.configure(blk, this, "R1");
  foreach(R2[i]) begin
    R2[i] = reg_type::type_id::create($sformatf("%s.R2[%d]",get_name(), i), null, blk.get_full_name());
    R2[i].configure(blk, this, $sformatf("R2[%d]", i));
    R2[i].build();
  end
  RF1 = reg_file_type2::type_id::create($sformatf("%s.rf1", get_name()), null, blk.get_full_name()); // RAL에서는 블록을 기준으로 cntxt를 제공함
  RF1.configure(blk, this, "RF1");
  RF1.build();
 
endfunction : build

virtual function void map(uvm_reg_map mp, uvm_reg_data_t offset);
mp.add_reg(R1, offset + 'h04, "RW");
foreach(R2[i]) begin
    int addr = 4 * i + 4;
    mp.add_reg(R2[i], offset + addr, "RW");
end
RF1.map(mp, offset + 'h200);
endfunction : map

endclass : reg_field_type


