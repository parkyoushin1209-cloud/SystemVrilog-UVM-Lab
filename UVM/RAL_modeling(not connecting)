class reg_block_type extends uvm_reg_block;
`uvm_object_utils(reg_block_type)

rand reg_type R1;
rand reg_file_type RF1;
rand reg_block1_type RB1;
mem_type M1;

covergroup cg_addr;
...
endgroup : cg_addr

function new(string name = "reg_block_t0ype");
super.new(name, build_coverage(UVM_CVR_ADDR_MAP));
if(has_coverage(UVM_CVR_ADDR_MAP)) cg_addr = new();
endfunction : new

virtual function void build();
R1 = reg_type::type_id::create("R1", null, get_full_name());
R1.configure(this, null,"R1");
R1.build();
RF1 = reg_file_type::type_id::create("RF1", null, get_full_name());
RF1.configure(this, null, "RF1");
RF1.build();
RB1 = reg_block1_type::type_id::create("RB1", null, get_full_name());
RB1.configure(this, "RB1");
RB1.build();
M1 = mem_type::type_id::create("M1", null, get_full_name());
M1.configure(this, "M1");
default_map = create_map("default_map", 'h1000, 4, UVM_LITTLE_ENDIAN);
default_map.add_reg(R1, 'h04, "RW");
default_map.add_mem(M1, 'h60, "RW");
RF1.map(default_map, 'h100);

lock_model()
endfunction : build

endclass : reg_block_type




