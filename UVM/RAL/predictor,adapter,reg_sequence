1. 암묵적 예측
HDL 경로가 사용될 경우 
루트 HDL 경로는 레지스터 모델을 인스턴스화 하는 환경 내에 반드시 명시
루트 경로의 값은 완전한 시뮬레이션 모델 내에서 DUT를 위한 모델의 장소에 의존할 것임

connect_phase
루트 블록과 버스 에이전트 연결 - if문으로 체크
어댑터 인스턴스화 

class block_env extends uvm_env;
`uvm_component_utils(block_env)

block_reg_model regmodel;
subblk_env subblk;
apb_adapter reg2apb;
apb_agent apb;

virtual function void build_phase(uvm_phase phase);
super.build_phase(phase);
if(regmodel == null) begin
regmodel = block_reg_model::type_id::create("regmodel");
regmodel.build();
regmodel.set_hdl_path_root("tb_top.dut");
regmodel.lock_model();
end
subblk = subblk_env::type_id::create("subblk", this);
subblk.regmodel = regmodel.subblk;
endfunction

virtual function void connect_phase(uvm_phase phase);
if(regmodel.get_parent() == null) begin
    reg2apb = apb_adapter::type_id::create("reg2apb");
    regmodel.APB.set_sequencer(apb.sequencer, reg2apb); // APB는 주소 맵
    regmodel.set_auto_predict(1);
    // 레지스터 모델 - 버스 에이전트 통합
end
endfunction 
endclass

//레지스터 시퀀스============================================
extends uvm_reg_sequence #(T_name) 형식으로 베이스 클래스 파라미터화도 가능함


class my_reg_sequence extends uvm_reg_sequence #(uvm_sequence #(apb_rw)); // 시퀀스이므로 파라미터 타입으로 시퀀스 필요
`uvm_object_utils(my_reg_sequence)

block_reg_model model;

virtual task body();
  uvm_status_e status;
  uvm_reg_data_t data;

  model.A.write(status, 'h33, .parent(this));
  if(status == UVM_NOT_OK)
    `uvm_error(...)
  
  model.A.read(status, data, .parent(this));
  if(data != 'h33)
    `uvm_error(...)
endtask : body

endclass : my_reg_sequence

//실행 방법
class my_test extends uvm_test;
block_env env;
virtual task run_phase(uvm_phase phase);
my_reg_sequence seq = my_req_sequence::type_id::create("seq");
seq.start(env.apb.sequencer);
endtask
endclass


